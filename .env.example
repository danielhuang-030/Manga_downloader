# 複製此檔為 .env 並填入實際值。勿將含真實 cookie 的 .env 提交版控。
#
# Docker Compose：專案根若同時有 docker-compose.yml 與 `.env`，Compose 會用 `.env` 做
# **變數替換**，cookie 內的 `$` 可能出現 WARN。請用：
#   docker compose --env-file compose.env run ...
# （應用程式仍由掛載的 `.env` 供 python-dotenv 讀取，與 compose.env 無關。）
#
# 優先順序：已在 shell 設定的環境變數優先於本檔（python-dotenv 預設不覆寫已存在變數）。
#
# 使用方式：填好後執行  python main_env.py
# （列表模式：python main.py；main_env 會讀取 main.py 的 settings 作為非 .env 欄位預設）

# 選填：viewer 模式下的網址模板，必須含 {id}；預設為 Bookwalker 台灣 browserViewer。
# MANGA_VIEWER_URL_TEMPLATE=https://www.bookwalker.com.tw/browserViewer/{id}/read

# 必填：與 main.py 內 settings["cookies"] 相同格式的 cookie 字串（分號分隔）。
MANGA_COOKIES=

# 必填：視窗／截圖寬高，格式為 寬x高（小寫 x），例如：
MANGA_RES=1445x2048

# 必填：每頁下載間隔秒數（可為小數）。
MANGA_SLEEP_TIME=1

# 必填：browserViewer 的數字 ID（依 MANGA_VIEWER_URL_TEMPLATE），多個以英文逗號分隔。
MANGA_IDS=000000

# 選填：headless 模式，見 downloader.py（new / old / 0 關閉）。
# MANGA_HEADLESS=new
